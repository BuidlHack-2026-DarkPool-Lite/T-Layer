{
  "name": "darkpool-contracts",
  "version": "1.0.0",
  "description": "DarkPool Lite – TEE-based private OTC swap contracts on BSC",
  "scripts": {
    "compile": "hardhat compile",
    "postcompile": "node ../../tools/sync-abi.mjs",
    "test": "hardhat test",
    "test:coverage": "hardhat coverage",
    "deploy:bsc-testnet": "hardhat run scripts/deploy.js --network bscTestnet",
    "deploy:opbnb-testnet": "hardhat run scripts/deploy.js --network opBNBTestnet",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "node": "hardhat node"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "hardhat": "^2.22.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^16.0.0"
  }
}
